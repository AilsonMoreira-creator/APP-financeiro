{
  "functions": {
    "api/ia-cron.js": { "maxDuration": 120 },
    "api/ia-disparar.js": { "maxDuration": 120 },
    "api/lojas-ia.js": { "maxDuration": 90 },
    "api/lojas-drive-importar.js": { "maxDuration": 300 },
    "api/lojas-drive-cron.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/bling-cron",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/ml-messages-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/ml-conversions-cron",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/ml-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/ml-ai-respond",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/ml-estoque-cron",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/bling-produtos-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/ia-cron?janela=manha",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/ia-cron?janela=tarde",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/ia-cron?janela=manha&escopo=marketplaces",
      "schedule": "15 10 * * *"
    },
    {
      "path": "/api/ia-cron?janela=tarde&escopo=marketplaces",
      "schedule": "15 17 * * *"
    },
    {
      "path": "/api/ia-cron?janela=manha&escopo=estoque",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/ia-cron?janela=tarde&escopo=estoque",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/lojas-drive-cron",
      "schedule": "0 9 * * 2"
    }
  ]
}
